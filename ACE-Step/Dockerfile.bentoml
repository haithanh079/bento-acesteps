# Custom Dockerfile for BentoML to fix pip/distutils issues
FROM nvidia/cuda:12.1.1-cudnn8-runtime-ubuntu20.04

# Set environment variables
ENV DEBIAN_FRONTEND=noninteractive
ENV PYTHONUNBUFFERED=1
ENV CUDA_VISIBLE_DEVICES=0
ENV TOKENIZERS_PARALLELISM=false

# Install system dependencies
RUN apt-get update && apt-get install -y \
    python3.11 \
    python3.11-dev \
    python3.11-venv \
    python3.11-distutils \
    python3-pip \
    python3-setuptools \
    python3-wheel \
    ffmpeg \
    libsndfile1 \
    libsndfile1-dev \
    libasound2-dev \
    portaudio19-dev \
    curl \
    wget \
    && rm -rf /var/lib/apt/lists/*

# Create symbolic links for python3.11
RUN ln -sf /usr/bin/python3.11 /usr/bin/python3 && \
    ln -sf /usr/bin/python3.11 /usr/bin/python

# Upgrade pip to latest version
RUN python3 -m pip install --upgrade pip

# Install uv using the upgraded pip
RUN pip install uv

# Create bentoml user
RUN groupadd -g 1034 -o bentoml && \
    useradd -m -u 1034 -g 1034 -o -r bentoml

# Set working directory
WORKDIR /home/bentoml/bento

# Copy bento files
COPY . /home/bentoml/bento/

# Set ownership
RUN chown -R bentoml:bentoml /home/bentoml/bento

# Switch to bentoml user
USER bentoml

# Install Python dependencies
RUN uv venv -p 3.11 /app/.venv && \
    /app/.venv/bin/pip install -r requirements_bentoml.txt

# Set environment for the virtual environment
ENV PATH="/app/.venv/bin:$PATH"

# Expose port
EXPOSE 3000

# Run the service
CMD ["python", "-m", "bentoml", "serve", "bentoml_service.openai_compatible_service:ACEStepOpenAIService", "--host", "0.0.0.0", "--port", "3000"]
