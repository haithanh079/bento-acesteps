FROM python:3.10-slim

# Set platform arguments
ARG TARGETPLATFORM
ARG BUILDPLATFORM

# Install system dependencies
RUN apt-get update && apt-get install -y \
    ffmpeg \
    libsndfile1 \
    libsndfile1-dev \
    libasound2-dev \
    portaudio19-dev \
    && rm -rf /var/lib/apt/lists/*

# Set working directory
WORKDIR /app

# Copy requirements
COPY requirements_bentoml.txt .

# Install Python dependencies
RUN pip install --no-cache-dir -r requirements_bentoml.txt

# Copy application code
COPY . .

# Set environment variables
ENV CUDA_VISIBLE_DEVICES=0
ENV TOKENIZERS_PARALLELISM=false
ENV PYTHONPATH=/app

# Expose port
EXPOSE 3000

# Run the service
CMD ["python", "-m", "bentoml", "serve", "bentoml_service.openai_compatible_service:ACEStepOpenAIService", "--host", "0.0.0.0", "--port", "3000"]
